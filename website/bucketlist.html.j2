{# Hidden page: /bucketlist. Data-driven from data/bucketlist.yaml (a simple
   list). Extends the shared base layout; not linked from the site, marked
   noindex. Generated to bucketlist.html by build.py: do NOT hand-edit. #}
{% extends "_layout.html.j2" %}

{% block title %}{{ title }} · {{ identity.name }}{% endblock %}
{% block description %}{{ description }}{% endblock %}
{% block head_extra %}<meta name="robots" content="noindex">{% endblock %}

{% block topbar %}
  <p class="backlink"><a href="/">← root</a></p>
{% endblock %}

{% block content %}
  <section class="bucketlist-section">
    {% if items %}
    <ol class="bucketlist">
      {% for it in items %}
      <li class="bucket-item{% if it.done %} is-done{% endif %}">{{ it.html }}</li>
      {% endfor %}
    </ol>
    {% else %}
    <p class="bio"><em>No items yet: add some in <code>data/bucketlist.yaml</code>.</em></p>
    {% endif %}
  </section>
{% endblock %}
