{# /tree: an interactive academic genealogy on an infinite canvas. Approach A:
   a tidy top-down tree seeded by a hierarchical layout, then gently relaxed
   (light anti-overlap repulsion + slow ambient drift + drag), heavily damped so
   it reads as a static tree that quietly breathes. Vanilla JS + SVG, no deps.
   Data from data/tree.yaml. Generated to tree.html by build.py: do NOT hand-edit. #}
{% extends "_layout.html.j2" %}

{% block title %}{{ title }} · {{ identity.name }}{% endblock %}
{% block description %}{{ description }}{% endblock %}
{% block head_extra %}<meta name="robots" content="noindex">{% endblock %}

{% block topbar %}
  <p class="backlink"><a href="/">← root</a></p>
{% endblock %}

{% block content %}
  <section class="tree-section">
    <h2>{{ title }}</h2>
    <p class="tree-hint" aria-hidden="true">drag to pan · scroll to zoom · drag a name to nudge it</p>
    <div class="tree-stage" hidden>
      <svg id="tree-canvas" role="img" aria-label="Academic genealogy graph">
        <g id="tree-viewport">
          <g id="tree-edges"></g>
          <g id="tree-nodes"></g>
        </g>
      </svg>
    </div>
    {% if tree.edges_named %}
    <ul class="tree-fallback">
      {% for e in tree.edges_named %}
      <li>{{ e.advisor }} <span aria-hidden="true">→</span><span class="sr-only"> advised </span> {{ e.student }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
{% endblock %}

{% block scripts %}
<script>
(function () {
  var DATA = {{ tree | tojson }};
  var nodes = (DATA && DATA.nodes) || [];
  var links = (DATA && DATA.links) || [];
  if (!nodes.length) return;

  var svg = document.getElementById('tree-canvas');
  var stage = document.querySelector('.tree-stage');
  var section = document.querySelector('.tree-section');
  var gViewport = document.getElementById('tree-viewport');
  var gEdges = document.getElementById('tree-edges');
  var gNodes = document.getElementById('tree-nodes');
  if (!svg || !stage) return;
  var NS = 'http://www.w3.org/2000/svg';

  // Progressive enhancement: reveal the canvas, hide the text outline.
  stage.hidden = false;
  if (section) section.classList.add('tree-live');

  var byId = {};
  nodes.forEach(function (n) { byId[n.id] = n; });
  var edges = [];
  links.forEach(function (l) {
    var s = byId[l.source], t = byId[l.target];
    if (s && t) edges.push({ s: s, t: t });
  });

  // --- tidy top-down layout: leaves get sequential x, parents center over kids ---
  var kids = {}, hasParent = {};
  nodes.forEach(function (n) { kids[n.id] = []; });
  edges.forEach(function (e) { kids[e.s.id].push(e.t); hasParent[e.t.id] = true; });
  var X_GAP = 190, Y_GAP = 120, leaf = 0, seen = {};
  function layout(n, depth) {
    if (seen[n.id]) return;        // cycle guard
    seen[n.id] = true;
    n.ty = depth * Y_GAP;
    var ch = kids[n.id];
    if (!ch.length) { n.tx = leaf * X_GAP; leaf++; return; }
    var sum = 0, c = 0;
    ch.forEach(function (k) { layout(k, depth + 1); if (typeof k.tx === 'number') { sum += k.tx; c++; } });
    n.tx = c ? sum / c : leaf * X_GAP;
  }
  nodes.filter(function (n) { return !hasParent[n.id]; }).forEach(function (r) { layout(r, 0); leaf++; });
  nodes.forEach(function (n) {
    if (typeof n.tx !== 'number') { n.tx = leaf * X_GAP; n.ty = 0; leaf++; }
    n.x = n.tx; n.y = n.ty; n.vx = 0; n.vy = 0; n.held = false;
    n.phase = (n.tx * 0.013) + (n.ty * 0.017);
  });

  // --- build SVG ---
  edges.forEach(function (e) {
    e.path = document.createElementNS(NS, 'path');
    e.path.setAttribute('class', 'tree-edge');
    gEdges.appendChild(e.path);
  });
  nodes.forEach(function (n) {
    var g = document.createElementNS(NS, 'g');
    g.setAttribute('class', 'tree-node' + (n.accent ? ' is-accent' : ''));
    var hit = document.createElementNS(NS, 'circle');
    hit.setAttribute('class', 'tree-hit'); hit.setAttribute('r', '24');
    g.appendChild(hit);
    var name = document.createElementNS(NS, 'text');
    name.setAttribute('class', 'tree-name');
    name.setAttribute('text-anchor', 'middle');
    name.setAttribute('dy', n.subtitle ? '-0.05em' : '0.32em');
    name.textContent = n.name;
    g.appendChild(name);
    if (n.subtitle) {
      var sub = document.createElementNS(NS, 'text');
      sub.setAttribute('class', 'tree-sub');
      sub.setAttribute('text-anchor', 'middle');
      sub.setAttribute('dy', '1.2em');
      sub.textContent = n.subtitle;
      g.appendChild(sub);
    }
    n.el = g;
    bindDrag(n, g);
    gNodes.appendChild(g);
  });

  // --- view transform (pan / zoom) + cursor field ---
  var view = { x: 0, y: 0, k: 1 };
  var mouse = { x: 0, y: 0, active: false };
  function applyView() {
    gViewport.setAttribute('transform',
      'translate(' + view.x + ',' + view.y + ') scale(' + view.k + ')');
  }
  function fit() {
    var minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    nodes.forEach(function (n) {
      if (n.tx < minX) minX = n.tx; if (n.tx > maxX) maxX = n.tx;
      if (n.ty < minY) minY = n.ty; if (n.ty > maxY) maxY = n.ty;
    });
    var r = svg.getBoundingClientRect();
    if (!r.width || !r.height) return;
    var pad = 90, w = (maxX - minX) || 1, h = (maxY - minY) || 1;
    var k = Math.min((r.width - pad * 2) / w, (r.height - pad * 2) / h, 1.15);
    if (!isFinite(k) || k <= 0) k = 1;
    view.k = k;
    view.x = r.width / 2 - ((minX + maxX) / 2) * k;
    view.y = pad - minY * k;
    applyView();
  }

  // --- physics: spring-to-target + soft anti-overlap + slow drift, well damped ---
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var K_SPRING = 0.02, DAMP = 0.85, MIN_DIST = 108, K_REPEL = 0.04, MAX_PUSH = 1.2, DRIFT = 2.2;
  // Subtle cursor field: nearby names ease a few px away from the pointer, then
  // the spring eases them back. CURSOR_MAX / K_SPRING bounds the displacement.
  var CURSOR_R = 170, K_CURSOR = 0.0014, CURSOR_MAX = 0.18;
  var t = 0, raf = 0;
  function step() {
    t += 0.016;
    var i, j, n;
    for (i = 0; i < nodes.length; i++) {
      n = nodes[i];
      var ax = n.tx + DRIFT * Math.sin(t * 0.34 + n.phase);
      var ay = n.ty + DRIFT * Math.cos(t * 0.29 + n.phase);
      n.fX = (ax - n.x) * K_SPRING;
      n.fY = (ay - n.y) * K_SPRING;
    }
    for (i = 0; i < nodes.length; i++) {
      for (j = i + 1; j < nodes.length; j++) {
        var a = nodes[i], b = nodes[j];
        var dx = a.x - b.x, dy = a.y - b.y;
        var d = Math.sqrt(dx * dx + dy * dy) || 0.01;
        if (d < MIN_DIST) {
          var mag = Math.min(K_REPEL * (MIN_DIST - d), MAX_PUSH);
          var ux = (dx / d) * mag, uy = (dy / d) * mag;
          a.fX += ux; a.fY += uy; b.fX -= ux; b.fY -= uy;
        }
      }
    }
    if (mouse.active) {
      for (i = 0; i < nodes.length; i++) {
        n = nodes[i];
        var cdx = n.x - mouse.x, cdy = n.y - mouse.y;
        var cd = Math.sqrt(cdx * cdx + cdy * cdy) || 0.01;
        if (cd < CURSOR_R) {
          var cmag = Math.min(K_CURSOR * (CURSOR_R - cd), CURSOR_MAX);
          n.fX += (cdx / cd) * cmag; n.fY += (cdy / cd) * cmag;
        }
      }
    }
    for (i = 0; i < nodes.length; i++) {
      n = nodes[i];
      if (n.held) { n.vx = 0; n.vy = 0; continue; }
      n.vx = (n.vx + n.fX) * DAMP;
      n.vy = (n.vy + n.fY) * DAMP;
      n.x += n.vx; n.y += n.vy;
    }
    render();
    raf = requestAnimationFrame(step);
  }
  function render() {
    var i;
    for (i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      n.el.setAttribute('transform', 'translate(' + n.x.toFixed(2) + ',' + n.y.toFixed(2) + ')');
    }
    for (i = 0; i < edges.length; i++) {
      var e = edges[i], s = e.s, u = e.t, my = (s.y + u.y) / 2;
      e.path.setAttribute('d',
        'M' + s.x.toFixed(2) + ',' + s.y.toFixed(2) +
        ' C' + s.x.toFixed(2) + ',' + my.toFixed(2) +
        ' ' + u.x.toFixed(2) + ',' + my.toFixed(2) +
        ' ' + u.x.toFixed(2) + ',' + u.y.toFixed(2));
    }
  }

  // --- interaction ---
  function toWorld(cx, cy) {
    var r = svg.getBoundingClientRect();
    return { x: (cx - r.left - view.x) / view.k, y: (cy - r.top - view.y) / view.k };
  }
  var panning = false, panLast = null;
  svg.addEventListener('pointerdown', function (e) {
    if (e.target.closest && e.target.closest('.tree-node')) return;
    panning = true; panLast = { x: e.clientX, y: e.clientY };
    try { svg.setPointerCapture(e.pointerId); } catch (err) {}
    svg.classList.add('is-grabbing');
  });
  svg.addEventListener('pointermove', function (e) {
    if (e.pointerType === 'mouse') {
      var w = toWorld(e.clientX, e.clientY);
      mouse.x = w.x; mouse.y = w.y; mouse.active = true;
    }
    if (!panning) return;
    view.x += e.clientX - panLast.x; view.y += e.clientY - panLast.y;
    panLast = { x: e.clientX, y: e.clientY }; applyView();
  });
  svg.addEventListener('pointerleave', function () { mouse.active = false; });
  function endPan() { panning = false; svg.classList.remove('is-grabbing'); }
  svg.addEventListener('pointerup', endPan);
  svg.addEventListener('pointercancel', endPan);
  svg.addEventListener('wheel', function (e) {
    e.preventDefault();
    var r = svg.getBoundingClientRect();
    var sx = e.clientX - r.left, sy = e.clientY - r.top;
    var wx = (sx - view.x) / view.k, wy = (sy - view.y) / view.k;
    var nk = Math.max(0.3, Math.min(3, view.k * Math.exp(-e.deltaY * 0.0015)));
    view.k = nk; view.x = sx - wx * nk; view.y = sy - wy * nk; applyView();
  }, { passive: false });
  function bindDrag(n, g) {
    g.addEventListener('pointerdown', function (e) {
      e.stopPropagation();
      n.held = true;
      try { g.setPointerCapture(e.pointerId); } catch (err) {}
      g.classList.add('is-held');
      var w = toWorld(e.clientX, e.clientY);
      n._ox = n.x - w.x; n._oy = n.y - w.y;
    });
    g.addEventListener('pointermove', function (e) {
      if (!n.held) return;
      var w = toWorld(e.clientX, e.clientY);
      n.x = w.x + n._ox; n.y = w.y + n._oy;
      if (reduce) render();
    });
    function release() { n.held = false; g.classList.remove('is-held'); }
    g.addEventListener('pointerup', release);
    g.addEventListener('pointercancel', release);
  }

  fit();
  render();
  if (!reduce) raf = requestAnimationFrame(step);
  window.addEventListener('resize', fit);
})();
</script>
{% endblock %}
