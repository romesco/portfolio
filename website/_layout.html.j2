{# Base layout shared by the homepage (index.html.j2) and standalone pages
   (page.html.j2). The generated *.html files are built from these by
   build.py and must NOT be hand-edited. #}
<!doctype html>
<html lang="en" data-build="{{ build_fp }}">
<head>
<!-- Hand-built by Rosario Scalise · rosarioscalise.com · All Rights Reserved.
     Forking this format? A quick hello first: rosario@cs.uw.edu -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noai, noimageai">
<title>{% block title %}{{ identity.name }}{% endblock %}</title>
<meta name="description" content="{% block description %}{{ description }}{% endblock %}">
{% block head_extra %}{% endblock %}
{% if analytics.umami_src and analytics.umami_id %}
<!-- Self-hosted Umami (cookieless analytics). Configured via site.yaml. -->
<script defer src="{{ analytics.umami_src }}" data-website-id="{{ analytics.umami_id }}"></script>
{% endif %}
<script>
  // Apply the saved theme before first paint to avoid a flash. Light is the
  // default (no attribute); only an explicit "dark" choice is applied.
  (function () {
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch (e) {}
  })();
</script>
<link rel="stylesheet" href="./styles.css?v={{ css_version }}">
<script>
  // Pick a random emoji from the pool (site.yaml `favicons:`) on each load
  // and render it as an inline SVG favicon: no asset files, no extra
  // requests. With JS off there's simply no custom icon.
  (function () {
    var icons = {{ favicons | tojson }};
    if (!icons || !icons.length) return;
    var emoji = icons[Math.floor(Math.random() * icons.length)];
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">'
      + '<text x="50" y="54" font-size="78" text-anchor="middle" '
      + 'dominant-baseline="central">' + emoji + '</text></svg>';
    var link = document.querySelector('link[rel~="icon"]') || document.createElement('link');
    link.setAttribute('rel', 'icon');
    link.setAttribute('href', 'data:image/svg+xml,' + encodeURIComponent(svg));
    document.head.appendChild(link);
  })();
</script>
</head>
<body>
<main>
{% block topbar %}{% endblock %}
  <header class="masthead">
    <a class="portrait-link" href="/bio" aria-label="About {{ identity.name }}" title="About {{ identity.name }}">
      <img class="portrait" src="{{ identity.headshot }}"
           alt="{{ identity.alt }}"
           width="120" height="120">
    </a>
    <div class="identity">
      <div class="identity-head">
        <h1><a class="name-link" href="/bio" title="About {{ identity.name }}">{{ identity.name }}</a></h1>
        <div class="head-tools">
          <button class="head-tool theme-toggle" type="button" aria-label="Switch to dark theme" title="Toggle light / dark theme">
            <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8z"/>
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4.2"/>
              <path d="M12 2.5v2.2M12 19.3v2.2M4.5 4.5l1.6 1.6M17.9 17.9l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.5 19.5l1.6-1.6M17.9 6.1l1.6-1.6"/>
            </svg>
          </button>
          <div class="head-tools-extra">
            <a class="head-tool reading-link" href="/reading" aria-label="Reading list" title="Reading list">
              <svg class="icon-books" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3.6" y="6.4" width="4" height="12.6" rx="0.4"/>
                <rect x="8.2" y="4.4" width="4" height="14.6" rx="0.4"/>
                <rect x="13.6" y="7.6" width="3.8" height="11.4" rx="0.4" transform="rotate(17 15.5 19)"/>
                <path d="M3 19.5h18"/>
              </svg>
            </a>
            <a class="head-tool garage-link" href="/garage" aria-label="Garage" title="Garage: experiments and sketches">
              <svg class="icon-garage" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3.5 10.5 12 6 20.5 10.5"/>
                <path d="M5 10v10h14V10"/>
                <path d="M7.5 20v-7h9v7"/>
                <path d="M7.5 15.7h9M7.5 17.9h9"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <p class="title">{{ identity.title }}</p>
      <p class="affiliation">{{ identity.affiliation }}</p>
      {% if show_masthead_bio and bio %}
      <p class="bio">{{ bio }}</p>
      {% endif %}
    </div>
  </header>

{% block content %}{% endblock %}
{% block footer %}
  <footer class="site-footer">© {{ year }} {{ identity.name }} · <a href="/license">terms</a></footer>
{% endblock %}
</main>
<script>
  // Theme toggle: flips data-theme on <html> and remembers the choice.
  // Lives in the base layout so it works on every page (home + standalone).
  (function () {
    var btn = document.querySelector('.theme-toggle');
    if (!btn) return;
    var root = document.documentElement;
    function sync() {
      var dark = root.getAttribute('data-theme') === 'dark';
      btn.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
      btn.setAttribute('aria-pressed', String(dark));
    }
    sync();
    btn.addEventListener('click', function () {
      var dark = root.getAttribute('data-theme') === 'dark';
      if (dark) root.removeAttribute('data-theme');
      else root.setAttribute('data-theme', 'dark');
      try { localStorage.setItem('theme', dark ? 'light' : 'dark'); } catch (e) {}
      sync();
    });
  })();
</script>
<script>
  // The "tl;dr" marker can sit inside a <summary>, so a tap would also toggle
  // the work's dropdown. Swallow its click (keep focus, which drives the popover
  // on touch). Shared so it works on the homepage and /publications.
  (function () {
    Array.prototype.forEach.call(document.querySelectorAll('.tldr-fn'), function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (typeof el.focus === 'function') el.focus();
      });
    });
  })();
</script>
{% block scripts %}{% endblock %}
{% if analytics.umami_src and analytics.umami_id %}
<script>
  // Outbound link tracking for Umami: tag every external link so a click fires
  // an "outbound" event carrying the destination URL. Umami auto-handles any
  // anchor with a data-umami-event attribute, so this just labels them.
  (function () {
    function tagOutbound() {
      var here = location.host;
      var links = document.querySelectorAll('a[href]');
      for (var i = 0; i < links.length; i++) {
        var a = links[i];
        if (a.hasAttribute('data-umami-event')) continue;
        try {
          var url = new URL(a.href, location.href);
          if (url.host && url.host !== here && /^https?:$/.test(url.protocol)) {
            a.setAttribute('data-umami-event', 'outbound');
            a.setAttribute('data-umami-event-url', url.href);
          }
        } catch (e) {}
      }
    }
    if (document.readyState !== 'loading') tagOutbound();
    else document.addEventListener('DOMContentLoaded', tagOutbound);
  })();
</script>
{% endif %}
{% if analytics.umami_src and analytics.umami_id %}
<script>
  // Richer Umami signals, both cookieless and inert until the tracker loads:
  //  1. Cross-device stitching for links you share personally (?v=<tag>).
  //  2. Engagement events so a single-page "/" visit is more than a 0s bounce.
  // Umami's built-in visit-duration and bounce count PAGEVIEW events only
  // (custom events don't move them), so #2 is read in the Events report, not
  // the headline "average visit time" (see github.com/umami-software/umami#3518).
  (function () {
    // The umami tracker is deferred: run fn once it exists (give up after ~8s).
    function ready(fn) {
      if (window.umami) return fn();
      var n = 0, t = setInterval(function () {
        if (window.umami) { clearInterval(t); fn(); }
        else if (++n > 20) { clearInterval(t); }
      }, 400);
    }
    function track(name, data) { ready(function () { try { umami.track(name, data); } catch (e) {} }); }

    // 0. Self-exclude. Visit /?notme once on each of your own devices to stop
    // counting yourself (Umami honors localStorage['umami.disabled']); /?trackme
    // re-enables. Takes effect from the next page load on that device.
    try {
      var sx = new URLSearchParams(location.search);
      if (sx.has('notme')) localStorage.setItem('umami.disabled', '1');
      if (sx.has('trackme')) localStorage.removeItem('umami.disabled');
    } catch (e) {}

    // 1. Cross-device stitch. Umami cannot merge an anonymous visitor's phone
    // and laptop on its own (there is no shared key). But a link you send with
    // ?v=<tag> tags this visit, and the tag is remembered on the device, so
    // every visit that used the link (any device) shares one distinct id you
    // can filter the dashboard by.
    try {
      var v = new URLSearchParams(location.search).get('v');
      var KEY = 'umami:v';
      if (v) { try { localStorage.setItem(KEY, v); } catch (e) {} }
      var stored = null;
      try { stored = localStorage.getItem(KEY); } catch (e) {}
      var id = v || stored;
      if (id) ready(function () { try { umami.identify(id, { via: v ? 'link' : 'return' }); } catch (e) {} });
    } catch (e) {}

    {% if analytics.engagement %}
    // 2. Engagement signals for this page view.
    var path = location.pathname;

    // Active time: tick a second only while the tab is visible AND recently
    // used, so idle/background tabs do not inflate it. Fire escalating
    // milestones so dwell is captured even if the exit event below is dropped.
    var active = 0, lastAct = Date.now(), IDLE = 20000, MILES = [15, 60, 180, 600], mi = 0;
    ['pointerdown', 'keydown', 'scroll', 'pointermove', 'touchstart'].forEach(function (ev) {
      addEventListener(ev, function () { lastAct = Date.now(); }, { passive: true });
    });
    setInterval(function () {
      if (document.visibilityState !== 'visible') return;
      if (Date.now() - lastAct > IDLE) return;
      active++;
      while (mi < MILES.length && active >= MILES[mi]) {
        track('engaged-time', { reached: MILES[mi] < 60 ? MILES[mi] + 's' : (MILES[mi] / 60) + 'm', path: path });
        mi++;
      }
    }, 1000);

    // Scroll depth: fire once each at 50% and 100% of the scrollable height.
    var DEPTHS = [50, 100], di = 0;
    function onScroll() {
      var el = document.documentElement, max = el.scrollHeight - el.clientHeight;
      var pct = max > 0 ? Math.round((el.scrollTop || document.body.scrollTop) / max * 100) : 100;
      while (di < DEPTHS.length && pct >= DEPTHS[di]) { track('scroll-depth', { pct: DEPTHS[di], path: path }); di++; }
      if (di >= DEPTHS.length) removeEventListener('scroll', onScroll);
    }
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Best-effort final dwell when the tab is hidden or closed, bucketed to keep
    // the Events report low-cardinality. May be dropped on a hard close; the
    // milestones above are the reliable signal.
    var sent = false;
    function dwell() {
      if (sent) return;
      sent = true;
      var b = active < 15 ? '<15s' : active < 60 ? '15-60s' : active < 180 ? '1-3m' : active < 600 ? '3-10m' : '10m+';
      track('page-dwell', { bucket: b, path: path });
    }
    addEventListener('visibilitychange', function () { if (document.visibilityState === 'hidden') dwell(); });
    addEventListener('pagehide', dwell);

    // Section attention: fire `section-view` once per [data-section] region when
    // it holds the viewport (>=50% of itself, or filling >=50% of the screen for
    // tall sections) for ~1s, so a quick scroll-past does not count. Shows which
    // parts of a page actually draw the eye, not just total dwell.
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          var el = en.target;
          var vh = window.innerHeight || document.documentElement.clientHeight || 1;
          var visible = en.isIntersecting &&
            (en.intersectionRatio >= 0.5 || en.intersectionRect.height >= vh * 0.5);
          if (visible) {
            if (el.__secFired || el.__secTimer) return;
            el.__secTimer = setTimeout(function () {
              el.__secFired = true; el.__secTimer = 0; io.unobserve(el);
              track('section-view', { name: el.getAttribute('data-section'), path: path });
            }, 1000);
          } else if (el.__secTimer) {
            clearTimeout(el.__secTimer); el.__secTimer = 0;
          }
        });
      }, { threshold: [0, 0.25, 0.5, 0.75, 1] });
      var secs = document.querySelectorAll('[data-section]');
      for (var si = 0; si < secs.length; si++) io.observe(secs[si]);
    }
    {% endif %}
  })();
</script>
{% endif %}
<script>
  // Internal attention overlay (Path A): visit any page with ?heatmap to tint
  // instrumented elements by engagement count (loads website/heatmap.js on
  // demand; no-op for normal visitors). Local-only by default; on the live site
  // use ?heatmap=live to force it (shows sample data). See docs/ANALYTICS.md.
  (function () {
    var qs = new URLSearchParams(location.search);
    if (!qs.has('heatmap')) return;
    var h = location.hostname, local = h === 'localhost' || h === '127.0.0.1' || h === '';
    if (!local && qs.get('heatmap') !== 'live') return;
    var s = document.createElement('script');
    s.src = '/heatmap.js?' + Date.now();
    document.body.appendChild(s);
  })();
</script>
</body>
</html>
