{# Hidden page: /twitter. A Twitter/X-style microblog feed driven by
   data/twitter.yaml, in the site's own style. Extends the shared layout;
   not linked from the site, marked noindex. Generated to twitter.html by
   build.py: do NOT hand-edit. #}
{% extends "_layout.html.j2" %}

{% block title %}{{ title }} · {{ identity.name }}{% endblock %}
{% block description %}{{ description }}{% endblock %}
{% block head_extra %}<meta name="robots" content="noindex">{% endblock %}

{% block topbar %}
  <p class="backlink"><a href="/">← root</a></p>
{% endblock %}

{% block content %}
  <section class="feed-section">
    <h2>{{ title }}</h2>
    {% if posts %}
    <div class="feed">
      {% for p in posts %}
      <article class="post">
        <div class="post-rail">
          {% if loop.first %}
          <img class="post-avatar" src="{{ identity.headshot }}" alt="" width="44" height="44">
          {% else %}
          <span class="post-dot" aria-hidden="true"></span>
          {% endif %}
        </div>
        <div class="post-body">
          <div class="post-head">
            {% if loop.first %}
            <span class="post-name">{{ identity.name }}</span>
            {% if handle %}<span class="post-handle">@{{ handle }}</span>{% endif %}
            <span class="post-sep" aria-hidden="true">·</span>
            {% endif %}
            <time class="post-time" datetime="{{ p.iso }}" title="{{ p.full }}">{{ p.display }}</time>
          </div>
          {% if p.repost %}
            {% if p.has_comment %}<div class="post-text">{{ p.html }}</div>{% endif %}
            {% if p.repost.source == 'instagram' %}
            {# Instagram repost in our card style: the post's own /embed/ iframe,
               cropped (.ig-embed-crop) to reveal just the photo. The cover link
               makes the whole image open the post; the iframe itself is inert. #}
            <div class="repost repost-instagram" style="--rp-aspect: {{ p.repost.aspect }};">
              {% if not p.has_comment %}<span class="repost-label" aria-hidden="true">↻ reposted</span>{% endif %}
              <span class="repost-head">
                <span class="repost-ig" aria-hidden="true"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="2.5" y="2.5" width="19" height="19" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1.35" fill="currentColor" stroke="none"/></svg></span>
                <span class="repost-name">{{ p.repost.author }}</span>
                {% if p.repost.handle %}<a class="repost-link" href="{{ p.repost.url }}">@{{ p.repost.handle }}</a>{% endif %}
              </span>
              <div class="ig-embed-crop">
                <iframe src="{{ p.repost.embed_src }}" title="Instagram post" loading="lazy" scrolling="no" allowtransparency="true"></iframe>
                <a class="ig-embed-cover" href="{{ p.repost.url }}" aria-label="View on Instagram"></a>
              </div>
              {% if p.repost.html %}<div class="repost-text">{{ p.repost.html }}</div>{% endif %}
              <a class="repost-source" href="{{ p.repost.url }}">instagram.com ↗</a>
            </div>
            {% elif p.repost.source == 'youtube' %}
            {# YouTube repost: thumbnail in our card that plays inline on hover
               (see the .yt-embed script), starting at `start`. The card links
               back to the channel; the cover/source links open the video. #}
            <div class="repost repost-youtube" style="--rp-aspect: {{ p.repost.aspect }};">
              {% if not p.has_comment %}<span class="repost-label" aria-hidden="true">↻ reposted</span>{% endif %}
              <span class="repost-head">
                <span class="repost-yt" aria-hidden="true"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6z"/></svg></span>
                <a class="repost-name repost-link" href="{{ p.repost.url }}">{{ p.repost.author }}</a>
              </span>
              <div class="yt-embed" data-embed="{{ p.repost.embed_src }}">
                <img class="yt-thumb" src="{{ p.repost.thumb }}" alt="" loading="lazy">
                <a class="yt-cover" href="{{ p.repost.video_url }}" aria-label="Watch on YouTube"><span class="yt-play" aria-hidden="true"></span></a>
              </div>
              {% if p.repost.html %}<div class="repost-text">{{ p.repost.html }}</div>{% endif %}
              <a class="repost-source" href="{{ p.repost.video_url }}">youtube.com ↗</a>
            </div>
            {% else %}
            <div class="repost">
              {% if not p.has_comment %}<span class="repost-label" aria-hidden="true">↻ reposted</span>{% endif %}
              <span class="repost-head">
                {% if p.repost.avatar %}
                <img class="repost-avatar" src="{{ p.repost.avatar }}" alt="" width="22" height="22">
                {% else %}
                <span class="repost-initials" aria-hidden="true">{{ p.repost.initials }}</span>
                {% endif %}
                <span class="repost-name">{{ p.repost.author }}</span>
                {% if p.repost.handle %}<a class="repost-link" href="{{ p.repost.url }}">@{{ p.repost.handle }}</a>{% endif %}
                <span class="post-sep" aria-hidden="true">·</span>
                <time class="post-time" datetime="{{ p.repost.iso }}" title="{{ p.repost.full }}">{{ p.repost.display }}</time>
              </span>
              <div class="repost-text">{{ p.repost.html }}</div>
            </div>
            {% endif %}
          {% else %}
          <div class="post-text">{{ p.html }}</div>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="bio"><em>No posts yet: add some in <code>data/twitter.yaml</code>.</em></p>
    {% endif %}
  </section>
{% endblock %}

{% block scripts %}
<script>
  // Turn each post's absolute timestamp into a live relative one ("now", "5m",
  // "3h", "2d"), falling back to an absolute date past a week. Runs at view
  // time, so it's always current; the server-rendered date is the no-JS value.
  (function () {
    function rel(d) {
      var s = (Date.now() - d.getTime()) / 1000;
      if (s < 45) return 'now';
      if (s < 3600) return Math.max(1, Math.floor(s / 60)) + 'm';
      if (s < 86400) return Math.floor(s / 3600) + 'h';
      if (s < 604800) return Math.floor(s / 86400) + 'd';
      var o = { month: 'short', day: 'numeric' };
      if (d.getFullYear() !== new Date().getFullYear()) o.year = 'numeric';
      return d.toLocaleDateString(undefined, o);
    }
    document.querySelectorAll('.post-time[datetime]').forEach(function (t) {
      var d = new Date(t.getAttribute('datetime'));
      if (!isNaN(d.getTime())) t.textContent = rel(d);
    });
  })();

  // YouTube reposts: play inline on hover (muted, from the start time baked into
  // data-embed), restore the thumbnail on leave. Click still opens the video on
  // YouTube via the cover link. A facade like this keeps the page light until
  // there's intent to watch.
  (function () {
    document.querySelectorAll('.yt-embed[data-embed]').forEach(function (box) {
      function play() {
        if (box.querySelector('.yt-frame')) return;
        var f = document.createElement('iframe');
        f.className = 'yt-frame';
        f.src = box.dataset.embed;
        f.allow = 'autoplay; encrypted-media; picture-in-picture';
        f.setAttribute('frameborder', '0');
        box.appendChild(f);
        box.classList.add('yt-playing');
      }
      function stop() {
        var f = box.querySelector('.yt-frame');
        if (f) f.remove();
        box.classList.remove('yt-playing');
      }
      box.addEventListener('mouseenter', play);
      box.addEventListener('mouseleave', stop);
    });
  })();
</script>
{% endblock %}
