{# Homepage. Extends the shared base layout (_layout.html.j2). Identity and
   publication data live in ../data/; page description, bio, and news live in
   site.yaml / ../data/news.yaml. index.html is regenerated by build.py and
   should NOT be hand-edited. #}
{% extends "_layout.html.j2" %}

{% block content %}
  {# Reusable "peek + fade" disclosure. The body passed via {% call %} is
     clipped to ~`peek` items by the index script, fading the cut-off, with
     a toggle to reveal the rest. With no JS nothing is clipped and the
     toggle stays hidden, so all content remains reachable. #}
  {% macro expandable(peek) %}
  <div class="expandable" data-expandable data-peek="{{ peek }}">
    <div class="expandable-viewport">
      {{ caller() }}
    </div>
    <button class="expandable-toggle" type="button" aria-expanded="false" hidden>
      <span class="expandable-label"></span>
      <svg class="expandable-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </button>
  </div>
  {% endmacro %}

  <p class="bio">{{ bio }}</p>

  {% if news %}
  <section class="news-section">
    <h2>News</h2>
    {% call expandable(3) %}
    <ul class="news">
      {% for n in news %}
      <li class="news-item">
        <time class="news-date" datetime="{{ n.iso }}">{{ n.date_display }}</time>
        <span class="news-text">{% if n.link %}<a href="{{ n.link }}">{{ n.text }}</a>{% else %}{{ n.text }}{% endif %}</span>
      </li>
      {% endfor %}
    </ul>
    {% endcall %}
  </section>
  {% endif %}

  <section class="works">
    <h2>Selected works</h2>
    {% if publications %}
    <ol class="works-list">
      {% for p in publications %}
      <li>
        <details class="work">
          <summary class="work-summary">
            <span class="work-title">{{ p.title }}</span>
            <span class="work-meta">{{ p.authors | authors }} <cite>{{ p.venue }}</cite>, {{ p.year }}.{% if p.links %} {{ p.links | links }}{% endif %}{% if p.awards %} <span class="award">{{ p.awards | join(' · ') }}</span>{% endif %}</span>
          </summary>
          <div class="work-media">
            {% if p.media and p.media.type == "video" %}
              {% if p.media.autoplay %}
              <video src="{{ p.media.src }}"
                     {% if p.media.poster %}poster="{{ p.media.poster }}"{% endif %}
                     muted loop playsinline preload="metadata"
                     data-autoplay-on-open></video>
              {% else %}
              <video src="{{ p.media.src }}"
                     {% if p.media.poster %}poster="{{ p.media.poster }}"{% endif %}
                     controls preload="metadata" playsinline></video>
              {% endif %}
            {% elif p.media and p.media.type == "image" %}
              <img src="{{ p.media.src }}" alt="{{ p.media.alt or p.title }}" loading="lazy">
            {% elif p.media and p.media.type == "youtube" and p.media.id %}
              <iframe src="https://www.youtube-nocookie.com/embed/{{ p.media.id }}"
                      loading="lazy"
                      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      title="Video: {{ p.title }}"></iframe>
            {% else %}
              <div class="work-media-placeholder" aria-label="Media placeholder">▶ media &middot; 16:9</div>
            {% endif %}
          </div>
        </details>
      </li>
      {% endfor %}
    </ol>
    {% else %}
    <p class="bio"><em>No publications marked <code>featured: true</code> in <code>publications.yaml</code> yet.</em></p>
    {% endif %}
  </section>

  {% if mentees %}
  <section class="mentoring-section">
    <h2>Mentoring</h2>
    {% call expandable(3) %}
    <ul class="mentoring">
      {% for m in mentees %}
      <li class="mentee">
        <span class="mentee-name">{{ m.name }}</span>
        {% if m.project %}<span class="mentee-project">{{ m.project }}</span>{% endif %}
        {% if m.current or m.years %}
        <span class="mentee-meta">{% if m.current %}{{ m.current }}{% endif %}{% if m.current and m.years %} · {% endif %}{% if m.years %}{{ m.years }}{% endif %}</span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% endcall %}
  </section>
  {% endif %}

  <section class="elsewhere-section">
    <h2>Elsewhere</h2>
    <ul class="elsewhere">
      {% if links.email %}<li><a href="mailto:{{ links.email }}">email</a></li>{% endif %}
      {% if links.scholar %}<li><a href="{{ links.scholar }}" rel="me">Google Scholar</a></li>{% endif %}
      {% if links.github %}<li><a href="{{ links.github }}" rel="me">GitHub</a></li>{% endif %}
      {% if links.orcid %}<li><a href="{{ links.orcid }}" rel="me">ORCID</a></li>{% endif %}
    </ul>
  </section>
{% endblock %}

{% block scripts %}
<script>
  // Wire up <details> open/close to play/pause any <video> inside that's
  // marked data-autoplay-on-open. We don't use the HTML `autoplay`
  // attribute because it fires on page load — we want play to start
  // when the user actually opens the dropdown.
  for (const v of document.querySelectorAll('details video[data-autoplay-on-open]')) {
    const d = v.closest('details');
    if (!d) continue;
    d.addEventListener('toggle', () => {
      if (d.open) {
        v.play().catch(() => {});
      } else {
        v.pause();
        v.currentTime = 0;
      }
    });
  }
</script>
<script>
  // Expandable "peek + fade" sections. Each [data-expandable] collapses its
  // viewport to roughly data-peek items, masks the cut-off into a fade, and
  // reveals the rest on click. Progressive enhancement: with JS off the
  // viewport is never clipped and the toggle stays hidden.
  (function () {
    var reduce = false;
    try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

    document.querySelectorAll('[data-expandable]').forEach(function (wrap) {
      var vp = wrap.querySelector('.expandable-viewport');
      var btn = wrap.querySelector('.expandable-toggle');
      var label = wrap.querySelector('.expandable-label');
      var list = vp && vp.querySelector('ul, ol');
      if (!vp || !btn || !label || !list) return;

      var peek = parseInt(wrap.getAttribute('data-peek'), 10) || 3;
      var items = list.children;
      var open = false;
      var peekPx = null;                       // current collapsed height (px)
      var canHover = false;
      try { canHover = window.matchMedia('(hover: hover)').matches; } catch (e) {}

      // Height that shows the first `peek` items fully, plus a small bleed so
      // the next item peeks under the fade as a hint. Measured live so it
      // tracks the real (re-wrapped) layout. null => content already fits.
      function peekHeight() {
        if (items.length <= peek) return null;
        var top = vp.getBoundingClientRect().top;
        var nth = items[peek - 1];
        return Math.round(nth.getBoundingClientRect().bottom - top + 14);
      }

      // How far the bottom eases down on hover: a fixed *fraction* of the
      // next hidden item rather than a flat distance, so short-item sections
      // (News) reveal a gentle sliver instead of lurching a whole line, while
      // tall sections (Mentoring) keep their fuller motion. Clamped for taste.
      function bumpPx() {
        var next = items[peek];                // first hidden item
        var ih = next ? next.getBoundingClientRect().height : 24;
        return Math.round(Math.min(24, Math.max(12, ih * 0.5)));
      }

      function collapse() {
        var h = peekHeight();
        if (h == null) {                       // fits — show all, no toggle
          btn.hidden = true;
          wrap.classList.remove('is-collapsed', 'is-open');
          vp.style.maxHeight = '';
          vp.style.overflow = '';
          peekPx = null;
          return;
        }
        open = false;
        peekPx = h;
        wrap.classList.add('is-collapsed');
        wrap.classList.remove('is-open');
        vp.style.overflow = 'clip';
        // Keep the hover bump if the pointer is already over the section, so
        // collapsing via "Show less" doesn't snap flat under the cursor.
        var hovering = canHover && !reduce && wrap.matches(':hover');
        vp.style.maxHeight = (hovering ? h + bumpPx() : h) + 'px';
        btn.setAttribute('aria-expanded', 'false');
        label.textContent = 'Show ' + (items.length - peek) + ' more';
        btn.hidden = false;
      }

      function expand() {
        open = true;
        wrap.classList.add('is-open');
        wrap.classList.remove('is-collapsed');
        btn.setAttribute('aria-expanded', 'true');
        label.textContent = 'Show less';
        if (reduce) {
          vp.style.maxHeight = 'none';
          vp.style.overflow = '';
          return;
        }
        vp.style.maxHeight = vp.scrollHeight + 'px';
        vp.addEventListener('transitionend', function te(e) {
          if (e.propertyName !== 'max-height') return;
          vp.removeEventListener('transitionend', te);
          if (open) { vp.style.maxHeight = 'none'; vp.style.overflow = ''; }
        });
      }

      function recollapse() {
        if (!reduce) {                         // pin current height to animate from
          vp.style.overflow = 'clip';
          vp.style.maxHeight = vp.scrollHeight + 'px';
          void vp.offsetHeight;                // force reflow
        }
        collapse();
      }

      btn.addEventListener('click', function () {
        if (open) recollapse(); else expand();
      });

      collapse();

      // Hover whisper (a touch of Option 2): the bottom eases down a little
      // on pointer hover, revealing a bit more under the (also-easing) fade.
      if (canHover && !reduce) {
        wrap.addEventListener('mouseenter', function () {
          if (!open && peekPx != null) vp.style.maxHeight = (peekPx + bumpPx()) + 'px';
        });
        wrap.addEventListener('mouseleave', function () {
          if (!open && peekPx != null) vp.style.maxHeight = peekPx + 'px';
        });
      }

      // Re-measure the peek when width changes (text re-wraps). Only while
      // collapsed; an open section is free-flowing.
      var raf = 0;
      window.addEventListener('resize', function () {
        if (open) return;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(function () {
          var h = peekHeight();
          if (h == null) { collapse(); return; }
          peekPx = h;
          var hovering = canHover && !reduce && wrap.matches(':hover');
          vp.style.maxHeight = (hovering ? h + bumpPx() : h) + 'px';
        });
      });
    });
  })();
</script>
{% endblock %}
