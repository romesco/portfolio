{# Homepage. Extends the shared base layout (_layout.html.j2). Identity and
   publication data live in ../data/; page description, bio, and news live in
   site.yaml / ../data/news.yaml. index.html is regenerated by build.py and
   should NOT be hand-edited. #}
{% extends "_layout.html.j2" %}
{% from "_works.html.j2" import work_list %}

{% block content %}
  {# Reusable "peek + fade" disclosure. The body passed via {% call %} is
     clipped to ~`peek` items by the index script, fading the cut-off, with
     a toggle to reveal the rest. With no JS nothing is clipped and the
     toggle stays hidden, so all content remains reachable. #}
  {% macro expandable(peek) %}
  <div class="expandable" data-expandable data-peek="{{ peek }}">
    <div class="expandable-viewport">
      {{ caller() }}
    </div>
    <button class="expandable-toggle" type="button" aria-expanded="false" hidden>
      <span class="expandable-label"></span>
      <svg class="expandable-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </button>
  </div>
  {% endmacro %}

  <p class="bio">{{ bio }}</p>

  {% if news %}
  <section class="news-section">
    <h2>News</h2>
    {% call expandable(3) %}
    <ul class="news">
      {% for n in news %}
      <li class="news-item">
        <time class="news-date" datetime="{{ n.iso }}">{{ n.date_display }}</time>
        <span class="news-text">{% if n.link %}<a href="{{ n.link }}">{{ n.html }}</a>{% else %}{{ n.html }}{% endif %}</span>
      </li>
      {% endfor %}
    </ul>
    {% endcall %}
  </section>
  {% endif %}

  <section class="works">
    <h2>Selected works{% if more_count %} <a class="works-more" href="/publications" title="See the full publication list">+{{ more_count }} more</a>{% endif %}</h2>
    {% if publications %}
    {{ work_list(publications) }}
    {% else %}
    <p class="bio"><em>No publications marked <code>featured: true</code> in <code>publications.yaml</code> yet.</em></p>
    {% endif %}
  </section>

  {% if mentees %}
  <section class="mentoring-section">
    <h2>Mentoring</h2>
    {% call expandable(3) %}
    <ul class="mentoring">
      {% for m in mentees %}
      <li class="mentee{% if m.year %} year-start{% endif %}">
        <span class="mentee-year">{% if m.year %}<span class="year-label">{{ m.year }}</span>{{ m.host_html }}{% endif %}</span>
        <span class="mentee-body">
          {% if m.url %}<a class="mentee-name" href="{{ m.url }}">{{ m.name }}</a>{% else %}<span class="mentee-name">{{ m.name }}</span>{% endif %}
          <span class="mentee-meta">{% if m.project_url %}<a class="mentee-project" href="{{ m.project_url }}">{{ m.project }}</a>{% else %}{{ m.project }}{% endif %}{% if m.span %} · {{ m.span }}{% endif %}{{ m.now_html }}</span>
        </span>
      </li>
      {% endfor %}
    </ul>
    {% endcall %}
  </section>
  {% endif %}

  <section class="elsewhere-section">
    <h2>Elsewhere</h2>
    <div class="elsewhere-row">
      <ul class="elsewhere">
      {% if links.email %}<li><a href="mailto:{{ links.email }}" aria-label="Email" title="Email"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></a></li>{% endif %}
      {% if links.scholar %}<li><a href="{{ links.scholar }}" rel="me" aria-label="Google Scholar" title="Google Scholar"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg></a></li>{% endif %}
      {% if links.github %}<li><a href="{{ links.github }}" rel="me" aria-label="GitHub" title="GitHub"><svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg></a></li>{% endif %}
      <li><a href="/twitter" aria-label="Twitter" title="Twitter"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.643 4.937c-.835.37-1.732.62-2.675.733.962-.576 1.7-1.49 2.048-2.578-.9.534-1.897.922-2.958 1.13-.85-.904-2.06-1.47-3.4-1.47-2.572 0-4.658 2.086-4.658 4.66 0 .364.042.718.12 1.06-3.873-.195-7.304-2.05-9.602-4.868-.4.69-.63 1.49-.63 2.342 0 1.616.823 3.043 2.072 3.878-.764-.025-1.482-.234-2.11-.583v.06c0 2.257 1.605 4.14 3.737 4.568-.392.106-.803.162-1.227.162-.3 0-.593-.028-.877-.082.593 1.85 2.313 3.198 4.352 3.234-1.595 1.25-3.604 1.995-5.786 1.995-.376 0-.747-.022-1.112-.065 2.062 1.323 4.51 2.093 7.14 2.093 8.57 0 13.255-7.098 13.255-13.254 0-.2-.005-.402-.014-.602.91-.658 1.7-1.477 2.323-2.41z"/></svg></a></li>
      <li><a href="/inthepress" aria-label="In the press" title="In the press"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M1.28 9.53 2.67 9.16 6.21 22.37 4.82 22.75ZM2.46 7.47 3.97 7.07 7.82 21.44 6.31 21.85ZM3.71 5.15 19.7 0.87 23.86 16.4 7.87 20.69ZM5.87 5.82 17.46 2.71 17.87 4.22 6.27 7.32ZM6.8 9.29 11.55 8.02 12.86 12.89 8.11 14.16ZM12.48 7.77 18.39 6.19 18.74 7.46 12.82 9.05ZM13.1 10.09 19.01 8.51 19.36 9.78 13.44 11.36ZM8.48 15.55 20.07 12.45 20.41 13.72 8.82 16.83ZM9.04 17.64 18.31 15.15 18.65 16.43 9.38 18.91Z"/></svg></a></li>
      <li><a href="/awards" aria-label="Awards and honors" title="Awards &amp; honors"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94A5.01 5.01 0 0 0 11 18.9V21H7v2h10v-2h-4v-2.1a5.01 5.01 0 0 0 3.61-2.96C19.08 13.63 21 11.55 21 9V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 1c0 1.3-.84 2.4-2 2.82V7h2v2z"/></svg></a></li>
      <li><a href="/teaching" aria-label="Teaching" title="Teaching"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 3H3a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8v2H8v2h8v-2h-3v-2h8a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1zm-1 12H4V5h16v10z"/></svg></a></li>
      <li><a href="/buymeacoffee" aria-label="Buy me a coffee" title="Buy me a coffee"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4.09 7.62 15.19 7.62 15.19 9.75 17.18 9.87 17.89 10.19 18.52 10.62 19.05 11.12 19.46 11.69 19.75 12.31 19.89 12.96 19.89 13.62 19.75 14.27 19.46 14.88 19.05 15.45 18.52 15.96 17.89 16.38 17.18 16.71 15.19 16.83 14.95 18.72 14.95 18.72 14.85 19.34 14.57 19.9 14.12 20.34 13.56 20.62 12.94 20.72 6.1 20.72 6.1 20.72 5.48 20.62 4.92 20.34 4.48 19.9 4.19 19.34 4.09 18.72 4.09 7.62ZM6.78 2.1 7.25 1.97 7.7 2.25 8.06 2.91 8.26 3.82 8.26 4.82 8.06 5.73 7.7 6.39 7.25 6.67 6.78 6.54 7.96 6.54 8.43 6.67 8.88 6.39 9.24 5.73 9.44 4.82 9.44 3.82 9.24 2.91 8.88 2.25 8.43 1.97 7.96 2.1ZM10.32 2.1 10.79 1.97 11.24 2.25 11.6 2.91 11.8 3.82 11.8 4.82 11.6 5.73 11.24 6.39 10.79 6.67 10.32 6.54 11.5 6.54 11.97 6.67 12.42 6.39 12.78 5.73 12.98 4.82 12.98 3.82 12.78 2.91 12.42 2.25 11.97 1.97 11.5 2.1ZM18.61 13.29 18.45 14.01 17.99 14.64 17.3 15.08 16.47 15.29 15.6 15.22 14.83 14.89 14.24 14.34 13.93 13.66 13.93 12.92 14.24 12.23 14.83 11.69 15.6 11.36 16.47 11.29 17.3 11.49 17.99 11.94 18.45 12.56 18.61 13.29Z"/></svg></a></li>
      </ul>
      <small class="copyright">© {{ year }} {{ identity.name }} · <a href="/license">terms</a></small>
    </div>
  </section>
{% endblock %}

{% block footer %}{% endblock %}

{% block scripts %}
<script>
  // Media inside each work's <details> dropdown. A single autoplay video
  // plays when the dropdown opens and resets on close. A carousel (multiple
  // clips) gets prev/next + dots, and only the active slide's video plays.
  // We avoid the HTML `autoplay` attribute (it fires on page load): playback
  // starts when the user actually opens the dropdown.
  (function () {
    function setupCarousel(root, details) {
      var track = root.querySelector('.carousel-track');
      var slides = Array.prototype.slice.call(root.querySelectorAll('.carousel-slide'));
      var dots = Array.prototype.slice.call(root.querySelectorAll('.carousel-dot'));
      var caption = root.querySelector('.carousel-caption');
      var prev = root.querySelector('.carousel-prev');
      var next = root.querySelector('.carousel-next');
      var n = slides.length, i = 0;

      function rest() { return -i * 100; }

      function sync() {
        track.style.transform = 'translateX(' + rest() + '%)';
        for (var k = 0; k < n; k++) {
          if (dots[k]) dots[k].classList.toggle('is-active', k === i);
          slides[k].setAttribute('aria-hidden', String(k !== i));
          var v = slides[k].querySelector('video');
          if (v) {
            if (k === i && details.open && v.hasAttribute('data-autoplay-on-open')) {
              v.play().catch(function () {});
            } else {
              v.pause();
              if (k !== i) { try { v.currentTime = 0; } catch (e) {} }
            }
          }
        }
        if (caption) {
          var label = slides[i].getAttribute('data-label') || '';
          caption.textContent = (label ? label + ' · ' : '') + (i + 1) + ' / ' + n;
        }
      }

      function go(step) { i = (i + step + n) % n; sync(); }
      if (prev) prev.addEventListener('click', function () { go(-1); });
      if (next) next.addEventListener('click', function () { go(1); });
      dots.forEach(function (dot, k) { dot.addEventListener('click', function () { i = k; sync(); }); });

      sync();
      return function () { sync(); };
    }

    document.querySelectorAll('details.work').forEach(function (d) {
      // Clicking the hover-revealed media sliver (the dropdown content) opens
      // the entry too: not just the summary text. Only while closed, so it
      // never interferes with carousel arrows / links / video controls once open.
      var content = d.querySelector('.work-media');
      if (content) {
        content.addEventListener('click', function () {
          if (!d.open) d.open = true;
        });
      }

      var carouselEl = d.querySelector('[data-carousel]');
      if (carouselEl) {
        var refresh = setupCarousel(carouselEl, d);
        d.addEventListener('toggle', refresh);
      } else {
        var v = d.querySelector('video[data-autoplay-on-open]');
        if (!v) return;
        d.addEventListener('toggle', function () {
          if (d.open) { v.play().catch(function () {}); }
          else { v.pause(); try { v.currentTime = 0; } catch (e) {} }
        });
      }
    });
  })();
</script>
<script>
  // Expandable "peek + fade" sections. Each [data-expandable] collapses its
  // viewport to roughly data-peek items, masks the cut-off into a fade, and
  // reveals the rest on click. Progressive enhancement: with JS off the
  // viewport is never clipped and the toggle stays hidden.
  (function () {
    var reduce = false;
    try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

    document.querySelectorAll('[data-expandable]').forEach(function (wrap) {
      var vp = wrap.querySelector('.expandable-viewport');
      var btn = wrap.querySelector('.expandable-toggle');
      var label = wrap.querySelector('.expandable-label');
      var list = vp && vp.querySelector('ul, ol');
      if (!vp || !btn || !label || !list) return;

      var peek = parseInt(wrap.getAttribute('data-peek'), 10) || 3;
      var items = list.children;
      var open = false;
      var peekPx = null;                       // current collapsed height (px)
      var canHover = false;
      try { canHover = window.matchMedia('(hover: hover)').matches; } catch (e) {}

      // Height that shows the first `peek` items fully, plus a small bleed so
      // the next item peeks under the fade as a hint. Measured live so it
      // tracks the real (re-wrapped) layout. null => content already fits.
      function peekHeight() {
        if (items.length <= peek) return null;
        var top = vp.getBoundingClientRect().top;
        var nth = items[peek - 1];
        return Math.round(nth.getBoundingClientRect().bottom - top + 14);
      }

      // How far the bottom eases down on hover: a fixed *fraction* of the
      // next hidden item rather than a flat distance, so short-item sections
      // (News) reveal a gentle sliver instead of lurching a whole line, while
      // tall sections (Mentoring) keep their fuller motion. Clamped for taste.
      function bumpPx() {
        var next = items[peek];                // first hidden item
        var ih = next ? next.getBoundingClientRect().height : 24;
        return Math.round(Math.min(24, Math.max(12, ih * 0.5)));
      }

      function collapse() {
        var h = peekHeight();
        if (h == null) {                       // fits: show all, no toggle
          btn.hidden = true;
          wrap.classList.remove('is-collapsed', 'is-open');
          vp.style.maxHeight = '';
          vp.style.overflow = '';
          peekPx = null;
          return;
        }
        open = false;
        peekPx = h;
        wrap.classList.add('is-collapsed');
        wrap.classList.remove('is-open');
        vp.style.overflow = 'clip';
        // Keep the hover bump if the pointer is already over the section, so
        // collapsing via "Show less" doesn't snap flat under the cursor.
        var hovering = canHover && !reduce && wrap.matches(':hover');
        vp.style.maxHeight = (hovering ? h + bumpPx() : h) + 'px';
        btn.setAttribute('aria-expanded', 'false');
        label.textContent = 'Show ' + (items.length - peek) + ' more';
        btn.hidden = false;
      }

      function expand() {
        open = true;
        wrap.classList.add('is-open');
        wrap.classList.remove('is-collapsed');
        btn.setAttribute('aria-expanded', 'true');
        label.textContent = 'Show less';
        if (reduce) {
          vp.style.maxHeight = 'none';
          vp.style.overflow = '';
          return;
        }
        vp.style.maxHeight = vp.scrollHeight + 'px';
        vp.addEventListener('transitionend', function te(e) {
          if (e.propertyName !== 'max-height') return;
          vp.removeEventListener('transitionend', te);
          if (open) { vp.style.maxHeight = 'none'; vp.style.overflow = ''; }
        });
      }

      function recollapse() {
        if (!reduce) {                         // pin current height to animate from
          vp.style.overflow = 'clip';
          vp.style.maxHeight = vp.scrollHeight + 'px';
          void vp.offsetHeight;                // force reflow
        }
        collapse();
      }

      btn.addEventListener('click', function () {
        if (open) recollapse(); else expand();
      });

      collapse();

      // Hover whisper (a touch of Option 2): the bottom eases down a little
      // on pointer hover, revealing a bit more under the (also-easing) fade.
      if (canHover && !reduce) {
        wrap.addEventListener('mouseenter', function () {
          if (!open && peekPx != null) vp.style.maxHeight = (peekPx + bumpPx()) + 'px';
        });
        wrap.addEventListener('mouseleave', function () {
          if (!open && peekPx != null) vp.style.maxHeight = peekPx + 'px';
        });
      }

      // Re-measure the peek when width changes (text re-wraps). Only while
      // collapsed; an open section is free-flowing.
      var raf = 0;
      window.addEventListener('resize', function () {
        if (open) return;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(function () {
          var h = peekHeight();
          if (h == null) { collapse(); return; }
          peekPx = h;
          var hovering = canHover && !reduce && wrap.matches(':hover');
          vp.style.maxHeight = (hovering ? h + bumpPx() : h) + 'px';
        });
      });
    });
  })();
</script>
<script>
  // Keep each work's author/venue line from running wider than its title:
  // cap the meta to the rendered title width. Re-measured after web fonts
  // load and on resize (the title re-wraps as the column changes). Manual
  // "//" breaks in the author list still apply within this cap.
  (function () {
    var summaries = Array.prototype.slice.call(document.querySelectorAll('.work-summary'));
    if (!summaries.length) return;
    function fit() {
      summaries.forEach(function (s) {
        var title = s.querySelector('.work-title');
        var meta = s.querySelector('.work-meta');
        if (!title || !meta) return;
        var w = Math.ceil(title.getBoundingClientRect().width);
        if (w > 0) meta.style.maxWidth = w + 'px';
      });
    }
    fit();
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
    window.addEventListener('load', fit);
    var t;
    window.addEventListener('resize', function () {
      clearTimeout(t);
      t = setTimeout(fit, 120);
    });
  })();
</script>
{% endblock %}
