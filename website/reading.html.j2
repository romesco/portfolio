{# Hidden page: /reading. A curated, grouped blogroll driven by
   data/reading.yaml. Extends the shared layout; not linked from the site,
   marked noindex. Generated to reading.html by build.py — do NOT hand-edit. #}
{% extends "_layout.html.j2" %}

{% block title %}{{ title }} · {{ identity.name }}{% endblock %}
{% block description %}{{ description }}{% endblock %}
{% block head_extra %}<meta name="robots" content="noindex">{% endblock %}

{% block topbar %}
  <p class="backlink"><a href="/">← {{ identity.name }}</a></p>
{% endblock %}

{% block content %}
  <section class="reading-section">
    <h2>{{ title }}</h2>
    {% if groups %}
    {% for g in groups %}
    <h3 class="reading-group">{{ g.name }}</h3>
    <ul class="reading">
      {% for ln in g.links %}
      <li class="read-item">
        {% if ln.favicon %}<img class="read-favicon" src="{{ ln.favicon }}" alt="" width="16" height="16" loading="lazy" onerror="this.style.visibility='hidden'">{% else %}<span class="read-favicon" aria-hidden="true"></span>{% endif %}
        <span class="read-head">
          <a class="read-name" href="{{ ln.url }}">{{ ln.name }}</a>
          {% if ln.domain %}<span class="read-domain">{{ ln.domain }}</span>{% endif %}
        </span>
        {% if ln.note %}<span class="read-note">{{ ln.note }}</span>{% endif %}
        {% if ln.latest %}
        <a class="read-latest" href="{{ ln.latest.url }}">
          <span class="read-latest-label">latest</span>
          <span class="read-latest-title">{{ ln.latest.title }}</span>
          {% if ln.latest.display %}<time class="read-latest-time" datetime="{{ ln.latest.iso }}" title="{{ ln.latest.full }}">{{ ln.latest.display }}</time>{% endif %}
        </a>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% endfor %}
    {% else %}
    <p class="bio"><em>No links yet — add some in <code>data/reading.yaml</code>.</em></p>
    {% endif %}
  </section>
{% endblock %}
