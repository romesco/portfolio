{# /awards: awards, fellowships, and honors, sourced from data/honors.yaml (the
   same list the CV uses, single source of truth). Years are intentionally
   omitted for now. Extends the shared layout. Generated to awards.html by
   build.py: do NOT hand-edit. #}
{% extends "_layout.html.j2" %}

{% block title %}{{ title }} · {{ identity.name }}{% endblock %}
{% block description %}{{ description }}{% endblock %}

{% block topbar %}
  <p class="backlink"><a href="/">← root</a></p>
{% endblock %}

{% block content %}
  <section class="awards-section">
    <h2>{{ title }}</h2>
    {% if honors %}
    <ul class="awards-list">
      {% for h in honors %}
      <li class="award-item">{{ h.name }}</li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="bio"><em>No honors recorded yet: add entries to <code>data/honors.yaml</code>.</em></p>
    {% endif %}
  </section>

  {% if grants %}
  <section class="grants-section">
    <h2>Grants Awarded</h2>
    <ul class="grants-list">
      {% for g in grants %}
      <li class="grant-item">
        <span class="grant-title">{{ g.title }}</span>
        {% if g.agency %}<span class="grant-agency">{{ g.agency }}</span>{% endif %}
        {% if g.amount %}<span class="grant-amount">{{ g.amount }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
{% endblock %}
