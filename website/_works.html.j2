{# Shared work-rail rendering for the homepage "Selected works" and the full
   /publications list. Both index.html and publications.html are generated by
   build.py from this; do NOT hand-edit the *.html output.

   work_list(pubs, full=false):
     full=false (homepage) renders every work as a <details> (media or a
       placeholder in the dropdown), exactly as Selected works always has.
     full=true (/publications) keeps media-bearing works expandable but renders
       media-less works as flat, non-expandable rows (no empty dropdowns). #}

{# A single media item (video / image / youtube / placeholder). #}
{% macro media_item(m, title) %}
  {% if m and m.type == "video" %}
    {% if m.autoplay %}
  <video src="{{ m.src }}"{% if m.poster %} poster="{{ m.poster }}"{% endif %}
         muted loop playsinline preload="metadata" data-autoplay-on-open></video>
    {% else %}
  <video src="{{ m.src }}"{% if m.poster %} poster="{{ m.poster }}"{% endif %}
         controls preload="metadata" playsinline></video>
    {% endif %}
  {% elif m and m.type == "image" %}
  <img src="{{ m.src }}" alt="{{ m.alt or title }}" loading="lazy">
  {% elif m and m.type == "youtube" and m.id %}
  <iframe src="https://www.youtube-nocookie.com/embed/{{ m.id }}"
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          title="Video: {{ title }}"></iframe>
  {% else %}
  <div class="work-media-placeholder" aria-label="Media placeholder">▶ media &middot; 16:9</div>
  {% endif %}
{% endmacro %}

{# Title + meta + TL;DR. Shared by the <summary> (expandable) and the flat row. #}
{% macro work_head(p) %}
<span class="work-title{% if p.title_nowrap %} work-title-nowrap{% endif %}">{{ p.title }}{% if p.short %} <span class="work-short">({{ p.short }})</span>{% endif %}{% if p.tldr and p.tldr_style == 'footnote' %} <span class="tldr-fn" tabindex="0" role="note" aria-label="TL;DR: {{ p.tldr }}">tl;dr<span class="tldr-pop">{{ p.tldr }}</span></span>{% endif %}</span>
            <span class="work-meta">{{ p.authors | authors }}{% if p.links %} {{ p.links | links }}{% endif %}{% if p.awards %} · <span class="award"{% if p.award_short %} title="{{ p.award_label }}"{% endif %}>{{ p.award_short or (p.awards | join(' · ')) }}</span>{% endif %}{% if p.collaborators %}{{ p.collaborators | collaborators }}{% endif %}{% if p.coverage %}{{ p.coverage | coverage }}{% endif %}</span>
            {% if p.tldr and p.tldr_style != 'footnote' %}<span class="work-tldr{% if p.tldr_style %} work-tldr-{{ p.tldr_style }}{% endif %}" title="{{ p.tldr }}"><strong class="work-tldr-label">TL;DR:</strong> {{ p.tldr }}</span>{% endif %}
{% endmacro %}

{% macro work_list(pubs, full=false) %}
    <ol class="works-list{% if not full %} works-list-solo{% endif %}">
      {% set ns = namespace(prev=None) %}
      {% for p in pubs %}
      {% set has_media = (p.media_list | length) > 0 %}
      {% set year_show = p.year != ns.prev %}
      {% set ns.prev = p.year %}
      <li class="work-row{% if year_show %} year-start{% endif %}">
        <div class="work-rail">
          <cite class="work-venue"{% if p.venue_full %} title="{{ p.venue_full }}"{% endif %}>{{ p.venue }}</cite>
          <span class="work-year">{{ p.year }}</span>
          {% if p.is_workshop %}
          <span class="work-kind"{% if p.venue_full %} title="{{ p.venue_full }}"{% endif %}>Workshop</span>
          {% endif %}
          {% if p.medal %}
          <span class="work-medal"{% if p.award_label %} title="{{ p.award_label }}"{% endif %} aria-label="{{ p.award_label or 'Award' }}">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M9.6 13 11.9 13 11.1 21.8 9.6 19.8 8 21.8ZM14.4 13 12.1 13 12.9 21.8 14.4 19.8 16 21.8Z"/><path fill-rule="evenodd" d="M12 2a6 6 0 1 1 0 12a6 6 0 1 1 0-12ZM12 4.2 12.94 6.71 15.61 6.83 13.52 8.49 14.23 11.07 12 9.6 9.77 11.07 10.48 8.49 8.39 6.83 11.06 6.71Z"/></svg>
            {% if p.award_at %}<span class="work-medal-at">@ {{ p.award_at }}</span>{% endif %}
          </span>
          {% endif %}
        </div>
        {% if has_media or not full %}
        <details class="work{% if has_media %} has-media{% endif %}">
          <summary class="work-summary">
            {{ work_head(p) }}
          </summary>
          <div class="work-media">
            {% set media = p.media_list %}
            {% if media | length > 1 %}
            <div class="carousel" data-carousel>
              <div class="carousel-viewport">
                <div class="carousel-track">
                  {% for m in media %}
                  <div class="carousel-slide" data-label="{{ m.label or '' }}" aria-hidden="{{ 'false' if loop.first else 'true' }}">
                    {{ media_item(m, p.title) }}
                  </div>
                  {% endfor %}
                </div>
                <button class="carousel-arrow carousel-prev" type="button" aria-label="Previous clip">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button class="carousel-arrow carousel-next" type="button" aria-label="Next clip">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
                </button>
              </div>
              <div class="carousel-bar">
                <span class="carousel-caption">{{ media[0].label or '' }}{% if media | length > 1 %} · 1 / {{ media | length }}{% endif %}</span>
                <div class="carousel-dots">
                  {% for m in media %}
                  <button class="carousel-dot{% if loop.first %} is-active{% endif %}" type="button" aria-label="{{ m.label or ('Clip ' ~ loop.index) }}"></button>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% elif media | length == 1 %}
            {{ media_item(media[0], p.title) }}
            {% else %}
            <div class="work-media-placeholder" aria-label="Media placeholder">▶ media &middot; 16:9</div>
            {% endif %}
          </div>
        </details>
        {% else %}
        <div class="work-summary work-flat">
            {{ work_head(p) }}
        </div>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
{% endmacro %}
