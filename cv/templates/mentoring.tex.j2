\resumeSubHeadingListStart
\#{ CV drops the " (RISE)" short-name from the project; the website keeps it. A mentee with no trajectory (empty 3rd arg) still gets the second line, so it spaces like the rest. }
\BLOCK{ for m in data.mentees }
\resumeMentee
{\textbf{\VAR{ m.name }} | \VAR{ m.project.replace(" (RISE)", "") }}{\VAR{ m.years.replace("-", " $\\rightarrow$ ") }}{\VAR{ (m.current or "").replace("->", "$\\rightarrow$") }}
\BLOCK{ endfor }
\BLOCK{ for o in data.other }
\resumeSubheadingSingleLine{\textbf{\VAR{ o }}}{Monthly}
\BLOCK{ endfor }
\BLOCK{ if data.leadership }
\resumeSubheadingSingleLine{}{}
\BLOCK{ for r in data.leadership }
\resumeSubheading
{\VAR{ r.role }}{\VAR{ r.years.replace("-", " $\\rightarrow$ ") }}
{\VAR{ r.org }}{}
\BLOCK{ endfor }
\BLOCK{ endif }
\resumeSubHeadingListEnd
